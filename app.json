{
  "expo": {
    "name": "MAURIPLAY",
    "slug": "mauriplay",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mauriplay",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f16"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mauriplay.app",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.mauriplay.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f0f16"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0f0f16",
      "themeColor": "#0f0f16",
      "preferRelatedApplications": false,
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/",
      "shortName": "MauriPlay",
      "description": "MauriPlay - Gaming Platform",
      "dir": "auto",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}